	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@tailwindcss/vite": "^4.2.2",
		"typescript": "^5.5.2",
		"vite": "^7.3.2",
		"wrangler": "^4.83.0"
	}
}
